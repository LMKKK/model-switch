{
  "name": "model-switch",
  "version": "1.3.0",
  "description": "CLI 工具，用于在不同 LLM 提供商之间切换 Codex/Claude Code 的模型配置",
  "module": "src/index.ts",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LMKKK/model-switch.git"
  },
  "bin": {
    "ms": "dist/ms.js"
  },
  "files": [
    "dist/"
  ],
  "engines": {
    "node": ">=16.0.0"
  },
  "keywords": [
    "claude-code",
    "codex-cli",
    "codex",
    "claude",
    "anthropic",
    "openai",
    "model-switch",
    "model",
    "switch",
    "llm",
    "cli"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --target node --banner '#!/usr/bin/env node' --outfile dist/ms.js",
    "compile": "bun build ./src/index.ts --compile --outfile bin/ms",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "@inquirer/prompts": "^8.4.3",
    "smol-toml": "^1.6.1"
  }
}
